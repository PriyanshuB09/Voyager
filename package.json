{
  "name": "frc-dashboard",
  "version": "1.0.0",
  "author": "Priyanshu Biswal",
  "description": "A custom dashboard for FRC",
  "main": "electron/main.ts",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"cross-env NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder build",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@frc-web-components/frc-web-components": "^4.5.3-alpha.0",
    "@frc-web-components/fwc": "^3.4.0",
    "@frc-web-components/react": "^2.1.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "lucide-react": "^0.545.0",
    "ntcore-react": "^2.0.3",
    "ntcore-ts-client": "^3.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.24",
    "electron": "^38.2.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.20"
  },
  "build": {
    "appId": "com.frcteam4188.cspdash",
    "productName": "CSP Dashboard",
    "win": {
      "icon": "build/icons/icon.ico",
      "target": "portable"
    },
    "linux": {
      "icon": "build/icons/256x256.png"
    }
  }
}
